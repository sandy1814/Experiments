pipeline {
    agent any

    stages {
        stage('No Docker') {
            steps {
                echo "No Docker"
                sh 'touch san.txt'
            }
        }
        stage('yes Docker') {
            agent {
                docker {
                    image 'node:18-alpine'
                    #reuseNode true
                }
            }
            steps {
                sh '''
                    echo "With Docker"
                    npm --version
                    touch san1.txt
                   '''
            }
        }
    }
}