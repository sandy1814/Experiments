pipeline {
    agent any

    stages {
        stage('No Docker') {
            steps {
                echo "No Docker"
            }
        }
        stage('yes Docker') {
            agent {
                docker {
                    image 'node:18-alpine'
                }
            }
            steps {
                sh '''
                    echo "With Docker"
                    npm --version
                   '''
            }
        }
    }
}