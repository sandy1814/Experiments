pipeline {
    agent any

    stages {
        stage('Docker') {
            steps {
                sh '''
                    docker build -t my-playwright .'
                    docker run --rm my-playwright netlify --version'
                    touch san.txt
                   '''
            }
        }
        stage('No Docker') {
            steps {
                echo "No Docker"
            }
        }
    }
}